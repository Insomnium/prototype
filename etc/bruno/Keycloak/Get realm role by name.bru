meta {
  name: Get realm role by name
  type: http
  seq: 8
}

get {
  url: http://localhost:9090/admin/realms/prototype/roles/users
  body: json
  auth: none
}

script:pre-request {
  const accessToken = bru.getEnvVar('keycloak_access_token');
  req.setHeader('Authorization', 'Bearer ' + accessToken);
}
